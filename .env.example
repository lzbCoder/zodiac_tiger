# 阿里百炼 API（必填）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 模型配置（阿里百炼平台）
CHAT_MODEL=qwen3.7-max
REASONING_MODEL=deepseek-v4-pro
INTENT_MODEL=qwen-turbo
MEMORY_SUMMARY_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=tiger
PG_SCHEMA=root
PG_USER=postgres
PG_PASSWORD=your_password_here

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=your_milvus_token_here
MILVUS_DATABASE=life_agent
MILVUS_COLLECTION_ASSISTANT=assistant_vector
MILVUS_COLLECTION_EPISODIC=episodic_memory
MILVUS_VECTOR_DIM=1024

# Redis
REDIS_URI=http://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# Tavily 联网搜索（可选）
TAVILY_API_KEY=your_tavily_api_key_here

# 高德地图 API（可选）
AMAP_API_KEY=your_amap_api_key_here

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LangSmith 监控（可选）
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=life-agent
